# ============================================
# liang_hua .gitignore
# ============================================

# 环境变量（含密钥，绝对不能提交）
.env

# Python 虚拟环境
venv/
env/
.venv/
.worktrees/
__pycache__/
.pytest_cache/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# 历史数据（体积大，每次重新拉即可）
data/*.csv

# 回测结果（程序生成）
results/*.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
Thumbs.db
Desktop.ini
.DS_Store

# 日志
*.log
logs/

# 临时文件
tmp/
temp/
*.tmp
