# ============================================
# liang_hua 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# .env 文件已被 .gitignore 忽略，不要提交到 git
# ============================================

# --- 交易所 API（第一阶段回测不需要，第二阶段模拟盘才用）---
# 第一阶段拉公开 K 线数据不需要 API key
# 币安 API Key（去 https://testnet.binance.vision/ 申请模拟盘 key）
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# 是否使用模拟盘（testnet）。第一阶段回测保持 false，第二阶段再改 true
BINANCE_TESTNET=false

# --- 网络（国内用户）---
# 代理地址，如 http://127.0.0.1:7890（Clash/V2Ray 等）
# HTTP_PROXY=

# 币安 API 地址（默认用国内站 api.binancezh.com，可覆盖）
# BINANCE_API_URL=

# --- Web 服务 ---
HOST=127.0.0.1
PORT=8000

# --- 数据 ---
DATA_DIR=./data

# --- 日志 ---
LOG_LEVEL=INFO
